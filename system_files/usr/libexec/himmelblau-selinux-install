#!/bin/bash

set -euo pipefail

SELINUX_SRC_DIR="/usr/share/selinux/packages/himmelblaud"
SELINUX_MAKEFILE="/usr/share/selinux/devel/Makefile"
MARKER_FILE="/var/lib/himmelblaud/.selinux-policy-installed"

log() {
    echo "[himmelblau-selinux-install] $*"
}

if [ -f "$MARKER_FILE" ]; then
    exit 0
fi

if ! command -v selinuxenabled >/dev/null 2>&1 || ! selinuxenabled; then
    log "SELinux is disabled or unavailable; skipping policy installation"
    exit 0
fi

if [ ! -d "$SELINUX_SRC_DIR" ]; then
    log "Policy source directory not found at $SELINUX_SRC_DIR"
    exit 0
fi

if [ ! -f "$SELINUX_MAKEFILE" ]; then
    log "SELinux development Makefile not found at $SELINUX_MAKEFILE"
    exit 1
fi

if ! command -v semodule >/dev/null 2>&1; then
    log "semodule is not available"
    exit 1
fi

mkdir -p /var/lib/himmelblaud
cd "$SELINUX_SRC_DIR"

rm -f himmelblaud.pp tmp/*.* 2>/dev/null || :
rmdir tmp 2>/dev/null || :

log "Building SELinux policy module"
make -f "$SELINUX_MAKEFILE" himmelblaud.pp

log "Installing SELinux policy module"
semodule -i himmelblaud.pp

rm -f himmelblaud.pp tmp/*.* 2>/dev/null || :
rmdir tmp 2>/dev/null || :

restorecon -Fv /usr/sbin/himmelblaud /usr/sbin/himmelblaud_tasks 2>/dev/null || :
[ -d /etc/himmelblau ] && restorecon -RFv /etc/himmelblau 2>/dev/null || :
[ -d /run/himmelblaud ] && restorecon -RFv /run/himmelblaud 2>/dev/null || :
[ -d /var/run/himmelblaud ] && restorecon -RFv /var/run/himmelblaud 2>/dev/null || :
[ -d /var/cache/private/himmelblaud ] && restorecon -RFv /var/cache/private/himmelblaud 2>/dev/null || :
[ -d /var/cache/himmelblaud ] && restorecon -RFv /var/cache/himmelblaud 2>/dev/null || :
[ -d /var/cache/nss-himmelblau ] && restorecon -RFv /var/cache/nss-himmelblau 2>/dev/null || :
[ -d /var/lib/private/himmelblaud ] && restorecon -RFv /var/lib/private/himmelblaud 2>/dev/null || :
[ -d /var/lib/himmelblaud ] && restorecon -RFv /var/lib/himmelblaud 2>/dev/null || :

touch "$MARKER_FILE"
log "SELinux policy module installed successfully"
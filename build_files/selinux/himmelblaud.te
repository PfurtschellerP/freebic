    allow NetworkManager_t himmelblau_var_run_t:dir { add_name getattr search write };
    allow NetworkManager_t himmelblau_var_run_t:sock_file { write };
    allow NetworkManager_t himmelblaud_t:unix_stream_socket { connectto };
    allow NetworkManager_t himmelblau_var_cache_t:dir { add_name getattr open read remove_name search write };
